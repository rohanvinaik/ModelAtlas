{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m lintgate.hooks.session_start",
            "timeout": 5
          }
        ],
        "matcher": "startup"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m lintgate.hooks.user_prompt",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m lintgate.hooks.pre_tool",
            "timeout": 3
          }
        ],
        "matcher": "Write|Edit|MultiEdit|Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m lintgate.hooks.pre_compact",
            "timeout": 5
          }
        ],
        "matcher": "auto|manual"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m lintgate.hooks.stop_gate",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m lintgate.hooks.session_end",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}