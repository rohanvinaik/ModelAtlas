<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.modelatlas.coherence</string>

    <!--
        Standalone coherence audit (read-only) — runs daily at 08:00.
        Useful when you want the health report decoupled from the sync
        routine (e.g., if sync runs less frequently than you want to
        watch for drift). The audit does not write to the DB; it only
        prints to the log.

        Skip loading this plist if the weekly sync plist's coherence
        coverage is enough.
    -->

    <key>ProgramArguments</key>
    <array>
        <string>/Users/rohanvinaik/tools/infrastructure/ModelAtlas/.venv/bin/python</string>
        <string>-m</string>
        <string>model_atlas.coherence</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/rohanvinaik/tools/infrastructure/ModelAtlas</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/modelatlas-coherence.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/modelatlas-coherence.err</string>
</dict>
</plist>
